// prisma/schema.prisma
// GénieBulletin — Schéma PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Configuration de l'établissement ─────────────────────────
model Config {
  id           Int    @id @default(autoincrement())
  nomEcole     String @default("")
  annee        String @default("")
  nomDirecteur String @default("")
  localite     String @default("")
  nomMaitre    String @default("")
  classeActive String @default("CI")
  divActive    String @default("A")

  @@map("config")
}

// ── Matières ──────────────────────────────────────────────────
model Matiere {
  id     Int    @id @default(autoincrement())
  nom    String
  coef   Int    @default(1)
  bareme Int    @default(20)
  ordre  Int    @default(0)

  notes Note[]

  @@map("matieres")
}

// ── Élèves ────────────────────────────────────────────────────
model Eleve {
  id        Int      @id @default(autoincrement())
  nom       String
  sexe      String
  niveau    String
  div       String
  createdAt DateTime @default(now())

  notes         Note[]
  appreciations Appreciation[]

  @@index([niveau, div])
  @@map("eleves")
}

// ── Notes ─────────────────────────────────────────────────────
model Note {
  id        Int    @id @default(autoincrement())
  eleveId   Int
  matiereId Int
  compo     Int
  valeur    Float?

  eleve   Eleve   @relation(fields: [eleveId], references: [id], onDelete: Cascade)
  matiere Matiere @relation(fields: [matiereId], references: [id], onDelete: Cascade)

  @@unique([eleveId, matiereId, compo])
  @@index([eleveId, compo])
  @@map("notes")
}

// ── Appréciations ─────────────────────────────────────────────
model Appreciation {
  id      Int    @id @default(autoincrement())
  eleveId Int
  compo   Int
  texte   String

  eleve Eleve @relation(fields: [eleveId], references: [id], onDelete: Cascade)

  @@unique([eleveId, compo])
  @@map("appreciations")
}