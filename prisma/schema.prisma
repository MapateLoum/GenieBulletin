generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nom       String
  role      String   @default("maitre")
  niveau    String?
  div       String?
  createdAt DateTime @default(now())

  @@map("users")
}

model Config {
  id           Int    @id @default(autoincrement())
  nomEcole     String @default("")
  annee        String @default("")
  nomDirecteur String @default("")
  localite     String @default("")
  nomMaitre    String @default("")
  classeActive String @default("CI")
  divActive    String @default("A")

  @@map("config")
}

model Matiere {
  id     Int    @id @default(autoincrement())
  nom    String
  coef   Float  @default(1)   // 👈 champ ajouté
  bareme Int    @default(20)
  ordre  Int    @default(0)
  niveau String
  div    String
  compo  Int    @default(1)

  notes Note[]

  @@index([niveau, div, compo])
  @@map("matieres")
}

model Eleve {
  id        Int      @id @default(autoincrement())
  nom       String
  sexe      String
  niveau    String
  div       String
  createdAt DateTime @default(now())

  notes         Note[]
  appreciations Appreciation[]

  @@index([niveau, div])
  @@map("eleves")
}

model Note {
  id        Int    @id @default(autoincrement())
  eleveId   Int
  matiereId Int
  compo     Int
  valeur    Float?

  eleve   Eleve   @relation(fields: [eleveId], references: [id], onDelete: Cascade)
  matiere Matiere @relation(fields: [matiereId], references: [id], onDelete: Cascade)

  @@unique([eleveId, matiereId, compo])
  @@index([eleveId, compo])
  @@map("notes")
}

model Appreciation {
  id      Int    @id @default(autoincrement())
  eleveId Int
  compo   Int
  texte   String

  eleve Eleve @relation(fields: [eleveId], references: [id], onDelete: Cascade)

  @@unique([eleveId, compo])
  @@map("appreciations")
}

model ResetToken {
  id        Int      @id @default(autoincrement())
  email     String
  token     String
  expiresAt DateTime
  used      Boolean  @default(false)

  @@map("reset_tokens")
}